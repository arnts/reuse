    "approach": {
      "type": "reuse-approach",
      "blocks": {
        "paragraph_1": {
          "type": "paragraph",
          "settings": {
            "text": "<p>Reggio Emilia-tradisjonen lærer oss at materialer er språk. Når vi tilbyr gjenbruksmaterialer fremfor ferdige produkter, skifter vi fokus fra <em>resultat</em> til <em>prosess</em>. Det er der den virkelige læringen og opplevelsen ligger.</p>"
          }
        },
        "paragraph_2": {
          "type": "paragraph",
          "settings": {
            "text": "<p>Materialer uten klare regler tvinger oss til å tenke selv. De er en demokratisk inngang som ikke favoriserer de som «kan», men inviterer alle.</p>"
          }
        }
      },
