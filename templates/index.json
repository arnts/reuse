    "introduction": {
      "type": "reuse-introduction",
      "blocks": {
        "value_1": {
          "type": "value",
          "settings": {
            "title": "Skapende prosesser",
            "text": "Hender, tanker og kropp flettes sammen rundt materialer som ikke har fasit."
          }
        },
        "value_2": {
          "type": "value",
          "settings": {
            "title": "Demokratiske materialer",
            "text": "Gjenbruksmaterialer har ingen regler — de inviterer alle aldre og kjønn inn på like vilkår."
          }
        },
        "value_3": {
          "type": "value",
          "settings": {
            "title": "Et frirom fra det digitale",
            "text": "Ekte møter, taktil utforskning og pause fra skjermer — for psykisk helse og fellesskap."
          }
        }
      },
      "block_order": [
        "value_1",
        "value_2",
        "value_3"
      ]
    },
