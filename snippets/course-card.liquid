{%- comment -%}
  Course card — used by the homepage featured-courses section and the course
  collection. The whole card is a single link (accessible); the CTA is a visual
  affordance, not a nested link. Availability comes from Shopify inventory.

  Accepts:
    product - (object) required
{%- endcomment -%}
{%- if product != blank -%}
  <article class="course-card">
    <a href="{{ product.url }}" class="course-card__link">
      <div class="course-card__image">
        {%- if product.featured_image -%}
          {{
            product.featured_image
            | image_url: width: 800
            | image_tag:
              loading: 'lazy',
              widths: '400, 600, 800',
              sizes: '(min-width: 720px) 33vw, 100vw',
              alt: product.featured_image.alt | default: product.title
          }}
        {%- endif -%}
      </div>
      <div class="course-card__body">
        {%- render 'course-availability', product: product -%}
        <h3 class="course-card__title">{{ product.title }}</h3>
        {%- render 'course-meta', product: product, layout: 'card' -%}
        {%- render 'course-price', product: product, class: 'course-card__price' -%}
        <span class="course-card__cta">
          {%- if product.available -%}{{ 'course.enroll' | t }}{%- else -%}{{ 'course.read_more' | t }}{%- endif -%}
          <span class="arrow" aria-hidden="true">&#8594;</span>
        </span>
      </div>
    </a>
  </article>
{%- endif -%}
