---
import type { Audience } from '../../data/audiences';

interface Props {
  audience: Audience;
  variant?: 'default' | 'compact';
}

const { audience, variant = 'default' } = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const href = `${base}/tilbud#${audience.id}`;
---

<a href={href} class:list={['audience-card', `audience-card--${variant}`]}>
  <div class="audience-card__image">
    <img src={`${base}${audience.image}`} alt={audience.imageAlt} loading="lazy" />
  </div>
  <div class="audience-card__body">
    <h3 class="audience-card__title">{audience.title}</h3>
    <p class="audience-card__tagline">{audience.tagline}</p>
    {variant !== 'compact' && <p class="audience-card__desc">{audience.description}</p>}
    <span class="audience-card__cta">
      Tilbud for {audience.shortTitle.toLowerCase()}
      <span class="arrow" aria-hidden="true">→</span>
    </span>
  </div>
</a>

<style>
  .audience-card {
    display: flex;
    flex-direction: column;
    background: var(--paper);
    border-radius: var(--radius-md);
    overflow: hidden;
    text-decoration: none;
    color: var(--ink);
    box-shadow: var(--shadow-soft);
    transition: transform var(--transition-medium), box-shadow var(--transition-medium);
    height: 100%;
  }

  .audience-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lift);
  }

  .audience-card:hover .arrow {
    transform: translateX(4px);
  }

  .audience-card:hover .audience-card__cta {
    color: var(--clay-dark);
  }

  .audience-card__image {
    aspect-ratio: 4 / 3;
    background: var(--cream-warm);
    overflow: hidden;
  }

  .audience-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-medium);
  }

  .audience-card:hover .audience-card__image img {
    transform: scale(1.04);
  }

  .audience-card__body {
    padding: var(--space-3);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    flex: 1;
  }

  .audience-card__title {
    font-size: 1.25rem;
    color: var(--ink);
    margin-bottom: 4px;
  }

  .audience-card__tagline {
    font-style: italic;
    color: var(--clay);
    font-size: 0.95rem;
    line-height: 1.4;
    font-family: var(--font-serif);
  }

  .audience-card__desc {
    color: var(--ink-soft);
    font-size: 0.94rem;
    line-height: 1.55;
    margin-block: var(--space-1) var(--space-2);
  }

  .audience-card__cta {
    margin-top: auto;
    padding-top: var(--space-2);
    color: var(--clay);
    font-weight: 500;
    font-size: 0.95rem;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: color var(--transition-fast);
  }

  .audience-card__cta .arrow {
    transition: transform var(--transition-fast);
  }
</style>
