---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  background?: 'cream' | 'cream-warm' | 'moss';
}

const { eyebrow, title, description, background = 'cream-warm' } = Astro.props;
---

<section class:list={['hero-page', `hero-page--${background}`]}>
  <div class="hero-page__inner">
    {eyebrow && <p class="hero-page__eyebrow">{eyebrow}</p>}
    <h1 class="hero-page__title">{title}</h1>
    {description && <p class="hero-page__description">{description}</p>}
  </div>
</section>

<style>
  .hero-page {
    position: relative;
    overflow: hidden;
  }

  .hero-page--cream {
    background: var(--cream);
  }

  .hero-page--cream-warm {
    background: var(--cream-warm);
  }

  .hero-page--moss {
    background: var(--moss);
    color: var(--cream);
  }

  .hero-page--moss .hero-page__title {
    color: var(--cream);
  }

  .hero-page--moss .hero-page__description {
    color: rgba(245, 239, 230, 0.85);
  }

  .hero-page--moss .hero-page__eyebrow {
    color: var(--ochre);
  }

  .hero-page::after {
    content: '';
    position: absolute;
    width: 360px;
    height: 360px;
    border-radius: 50%;
    background: var(--ochre);
    opacity: 0.18;
    top: -120px;
    right: -120px;
    pointer-events: none;
  }

  .hero-page--moss::after {
    background: var(--clay);
    opacity: 0.45;
  }

  .hero-page__inner {
    position: relative;
    max-width: var(--max-content);
    margin-inline: auto;
    padding: var(--space-6) var(--space-3);
  }

  @media (min-width: 768px) {
    .hero-page__inner {
      padding: var(--space-7) var(--space-5);
    }
  }

  .hero-page__eyebrow {
    display: inline-block;
    font-size: 0.78rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--ochre-dark);
    margin-bottom: var(--space-2);
  }

  .hero-page__title {
    font-size: clamp(2.2rem, 5vw, 3.6rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    max-width: 18ch;
    margin-bottom: var(--space-3);
  }

  .hero-page__description {
    font-size: clamp(1.05rem, 1.6vw, 1.2rem);
    color: var(--ink-soft);
    line-height: 1.55;
    max-width: 640px;
  }
</style>
