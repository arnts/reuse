---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const link = (path: string) => `${base}${path}`;
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-grid">
      <div class="footer-col footer-col--brand">
        <p class="footer-brand">REuse Atelier</p>
        <p class="footer-tagline">
          Et atelier for skapende prosesser med gjenbruksmaterialer — i Oslo.
        </p>
      </div>

      <div class="footer-col">
        <p class="footer-heading">Naviger</p>
        <ul>
          <li><a href={link('/')}>Hjem</a></li>
          <li><a href={link('/tilbud')}>Tilbud</a></li>
          <li><a href={link('/om')}>Om oss</a></li>
          <li><a href={link('/kontakt')}>Kontakt</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <p class="footer-heading">Kontakt</p>
        <ul>
          <li><a href={link('/kontakt')}>Send forespørsel →</a></li>
          <li>
            <a
              href="https://www.instagram.com/"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="REuse Atelier på Instagram"
            >
              Instagram (kommer)
            </a>
          </li>
        </ul>
      </div>

      <div class="footer-col">
        <p class="footer-heading">Sted</p>
        <p class="footer-text">Grønland / Tøyen<br />Oslo, Norge</p>
        <p class="footer-text footer-text--small">Lokaler under planlegging</p>
      </div>
    </div>

    <div class="footer-bar">
      <p>© {year} REuse Atelier</p>
      <p class="footer-bar__credit">Laget med omtanke</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--moss);
    color: var(--cream);
    padding-block: var(--space-6) var(--space-3);
    margin-top: auto;
  }

  .footer-inner {
    max-width: var(--max-content);
    margin-inline: auto;
    padding-inline: var(--space-3);
  }

  @media (min-width: 768px) {
    .footer-inner {
      padding-inline: var(--space-5);
    }
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    padding-bottom: var(--space-5);
    border-bottom: 1px solid rgba(245, 239, 230, 0.18);
  }

  @media (min-width: 600px) {
    .footer-grid {
      grid-template-columns: 1.5fr 1fr 1fr 1fr;
      gap: var(--space-3);
    }
  }

  .footer-col--brand {
    max-width: 320px;
  }

  .footer-brand {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 500;
    color: var(--cream);
    margin-bottom: var(--space-1);
  }

  .footer-tagline {
    color: rgba(245, 239, 230, 0.78);
    font-size: 0.95rem;
    line-height: 1.55;
  }

  .footer-heading {
    font-family: var(--font-serif);
    font-size: 1rem;
    font-weight: 500;
    color: var(--ochre);
    margin-bottom: var(--space-2);
    letter-spacing: 0.02em;
  }

  .footer-col ul {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer-col a {
    color: rgba(245, 239, 230, 0.85);
    font-size: 0.95rem;
    transition: color var(--transition-fast);
  }

  .footer-col a:hover {
    color: var(--ochre);
  }

  .footer-text {
    color: rgba(245, 239, 230, 0.85);
    font-size: 0.95rem;
    line-height: 1.55;
    margin-bottom: var(--space-1);
  }

  .footer-text--small {
    font-size: 0.85rem;
    color: rgba(245, 239, 230, 0.6);
    font-style: italic;
  }

  .footer-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-2);
    padding-top: var(--space-3);
    color: rgba(245, 239, 230, 0.55);
    font-size: 0.85rem;
  }

  .footer-bar__credit {
    font-style: italic;
  }
</style>
