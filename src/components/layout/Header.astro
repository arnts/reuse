---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const link = (path: string) => `${base}${path}`;
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';

const navItems = [
  { href: link('/'), label: 'Hjem' },
  { href: link('/tilbud'), label: 'Tilbud' },
  { href: link('/om'), label: 'Om oss' },
  { href: link('/kontakt'), label: 'Kontakt' },
];

const isActive = (href: string) => {
  const normalized = href.replace(/\/$/, '') || '/';
  if (normalized === '/') {
    return currentPath === '/' || currentPath === base || currentPath === `${base}/`;
  }
  return currentPath === normalized || currentPath.startsWith(`${normalized}/`);
};
---

<header class="site-header" id="site-header">
  <div class="header-inner">
    <a href={link('/')} class="brand" aria-label="REuse Atelier — til forsiden">
      <img
        src={link('/images/brand/logo.png')}
        alt="REuse Atelier — Kreative hender & Kreative hoder"
        class="brand__logo"
        width="4000"
        height="1432"
      />
    </a>

    <button class="menu-toggle" aria-label="Åpne meny" aria-expanded="false" aria-controls="primary-nav">
      <span class="menu-toggle__bar"></span>
      <span class="menu-toggle__bar"></span>
      <span class="menu-toggle__bar"></span>
    </button>

    <nav id="primary-nav" class="primary-nav" aria-label="Hovednavigasjon">
      <ul class="nav-list">
        {
          navItems.map((item) => (
            <li>
              <a
                href={item.href}
                class:list={['nav-link', isActive(item.href) && 'is-active']}
                aria-current={isActive(item.href) ? 'page' : undefined}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
      <a href={link('/kontakt')} class="btn btn--clay btn--small header-cta">
        Send forespørsel
        <span class="arrow" aria-hidden="true">→</span>
      </a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(245, 239, 230, 0.92);
    backdrop-filter: saturate(140%) blur(10px);
    -webkit-backdrop-filter: saturate(140%) blur(10px);
    border-bottom: 1px solid var(--hairline);
    transition: background var(--transition-fast), box-shadow var(--transition-fast);
  }

  .site-header.is-scrolled {
    background: rgba(245, 239, 230, 0.97);
    box-shadow: 0 2px 16px rgba(44, 40, 37, 0.06);
  }

  .header-inner {
    max-width: var(--max-content);
    margin-inline: auto;
    padding: var(--space-2) var(--space-3);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    min-height: var(--header-height);
    transition: min-height var(--transition-fast);
  }

  .site-header.is-scrolled .header-inner {
    min-height: var(--header-height-shrunk);
  }

  @media (min-width: 768px) {
    .header-inner {
      padding-inline: var(--space-5);
    }
  }

  .brand {
    display: inline-flex;
    align-items: center;
    color: var(--ink);
    text-decoration: none;
    border-radius: var(--radius-sm);
  }

  .brand__logo {
    display: block;
    height: 48px;
    width: auto;
    border-radius: var(--radius-sm);
    transition: height var(--transition-fast);
  }

  .site-header.is-scrolled .brand__logo {
    height: 40px;
  }

  @media (max-width: 480px) {
    .brand__logo {
      height: 40px;
    }

    .site-header.is-scrolled .brand__logo {
      height: 34px;
    }
  }

  .primary-nav {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .nav-list {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .nav-link {
    color: var(--ink);
    font-weight: 500;
    font-size: 0.96rem;
    padding: var(--space-1) 0;
    position: relative;
    text-decoration: none;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -2px;
    height: 1.5px;
    background: var(--clay);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--transition-fast);
  }

  .nav-link:hover {
    color: var(--clay);
  }

  .nav-link:hover::after,
  .nav-link.is-active::after {
    transform: scaleX(1);
  }

  .nav-link.is-active {
    color: var(--clay);
  }

  .menu-toggle {
    display: none;
    width: 44px;
    height: 44px;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    border-radius: var(--radius-sm);
  }

  .menu-toggle__bar {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--ink);
    transition: transform var(--transition-fast), opacity var(--transition-fast);
  }

  .menu-toggle[aria-expanded='true'] .menu-toggle__bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .menu-toggle[aria-expanded='true'] .menu-toggle__bar:nth-child(2) {
    opacity: 0;
  }

  .menu-toggle[aria-expanded='true'] .menu-toggle__bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  @media (max-width: 880px) {
    .menu-toggle {
      display: flex;
    }

    .primary-nav {
      position: fixed;
      inset: var(--header-height) 0 0 0;
      background: var(--cream);
      flex-direction: column;
      align-items: stretch;
      justify-content: flex-start;
      padding: var(--space-5) var(--space-3);
      gap: var(--space-3);
      transform: translateX(100%);
      transition: transform var(--transition-medium);
      overflow-y: auto;
    }

    .primary-nav.is-open {
      transform: translateX(0);
    }

    .nav-list {
      flex-direction: column;
      align-items: stretch;
      gap: 0;
    }

    .nav-list li {
      border-bottom: 1px solid var(--hairline);
    }

    .nav-link {
      display: block;
      padding: var(--space-3) 0;
      font-size: 1.4rem;
      font-family: var(--font-serif);
    }

    .nav-link::after {
      display: none;
    }

    .header-cta {
      align-self: stretch;
      margin-top: var(--space-3);
      justify-content: center;
    }
  }
</style>

<script>
  // Sticky shrink + mobile menu
  const header = document.getElementById('site-header');
  const toggle = header?.querySelector<HTMLButtonElement>('.menu-toggle');
  const nav = header?.querySelector<HTMLElement>('.primary-nav');

  if (header) {
    const onScroll = () => {
      header.classList.toggle('is-scrolled', window.scrollY > 12);
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  }

  if (toggle && nav) {
    toggle.addEventListener('click', () => {
      const isOpen = nav.classList.toggle('is-open');
      toggle.setAttribute('aria-expanded', String(isOpen));
      toggle.setAttribute('aria-label', isOpen ? 'Lukk meny' : 'Åpne meny');
      document.body.style.overflow = isOpen ? 'hidden' : '';
    });

    nav.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        nav.classList.remove('is-open');
        toggle.setAttribute('aria-expanded', 'false');
        toggle.setAttribute('aria-label', 'Åpne meny');
        document.body.style.overflow = '';
      });
    });
  }
</script>
