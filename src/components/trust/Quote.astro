---
interface Props {
  attribution?: string;
  size?: 'default' | 'large';
}

const { attribution, size = 'default' } = Astro.props;
---

<figure class:list={['quote', `quote--${size}`]}>
  <span class="quote__mark" aria-hidden="true">«</span>
  <blockquote>
    <slot />
  </blockquote>
  {attribution && <figcaption>— {attribution}</figcaption>}
</figure>

<style>
  .quote {
    position: relative;
    padding: var(--space-3) var(--space-2);
  }

  @media (min-width: 768px) {
    .quote {
      padding: var(--space-4);
    }
  }

  .quote--large {
    text-align: center;
    max-width: 780px;
    margin-inline: auto;
  }

  .quote__mark {
    font-family: var(--font-serif);
    font-size: 6rem;
    line-height: 0.8;
    color: var(--ochre);
    position: absolute;
    top: 0;
    left: -12px;
    opacity: 0.55;
    user-select: none;
  }

  .quote--large .quote__mark {
    position: static;
    display: block;
    margin-bottom: var(--space-1);
  }

  .quote blockquote {
    font-family: var(--font-serif);
    font-size: clamp(1.3rem, 2.4vw, 1.8rem);
    line-height: 1.4;
    color: var(--ink);
    font-style: italic;
    font-weight: 400;
    max-width: none;
  }

  .quote--large blockquote {
    font-size: clamp(1.5rem, 2.8vw, 2.2rem);
  }

  .quote figcaption {
    margin-top: var(--space-2);
    font-size: 0.92rem;
    color: var(--ink-soft);
    font-style: normal;
    letter-spacing: 0.04em;
  }
</style>
