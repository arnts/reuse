---
interface Props {
  name: string;
  role: string;
  image: string;
  imageAlt: string;
  credentials: string[];
  bio: string;
}

const { name, role, image, imageAlt, credentials, bio } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<article class="team-card">
  <div class="team-card__portrait">
    <img src={`${base}${image}`} alt={imageAlt} loading="lazy" />
  </div>
  <div class="team-card__body">
    <p class="team-card__role">{role}</p>
    <h3 class="team-card__name">{name}</h3>
    <ul class="team-card__credentials">
      {credentials.map((c) => <li>{c}</li>)}
    </ul>
    <p class="team-card__bio">{bio}</p>
  </div>
</article>

<style>
  .team-card {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-3);
    background: var(--paper);
    padding: var(--space-3);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-soft);
  }

  @media (min-width: 600px) {
    .team-card {
      grid-template-columns: 220px 1fr;
      gap: var(--space-4);
      padding: var(--space-4);
    }
  }

  .team-card__portrait {
    aspect-ratio: 1;
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--cream-warm);
  }

  .team-card__portrait img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .team-card__role {
    font-size: 0.78rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--clay);
    margin-bottom: 4px;
  }

  .team-card__name {
    font-size: 1.8rem;
    margin-bottom: var(--space-2);
  }

  .team-card__credentials {
    margin-bottom: var(--space-2);
    padding-bottom: var(--space-2);
    border-bottom: 1px solid var(--hairline);
  }

  .team-card__credentials li {
    color: var(--ink);
    font-size: 0.93rem;
    line-height: 1.55;
    padding-left: 18px;
    position: relative;
  }

  .team-card__credentials li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 11px;
    width: 8px;
    height: 1.5px;
    background: var(--ochre);
  }

  .team-card__bio {
    color: var(--ink-soft);
    font-size: 1rem;
    line-height: 1.65;
  }
</style>
