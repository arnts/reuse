---
interface Credential {
  label: string;
  detail?: string;
}

interface Props {
  items?: Credential[];
}

const defaults: Credential[] = [
  { label: 'Reggio Emilia-instituttet', detail: 'Stockholm' },
  { label: 'Atelierista', detail: 'utdanning' },
  { label: 'Pedagogista', detail: 'utdanning' },
  { label: 'Master estetiske fag', detail: 'Oslomet' },
  { label: 'Lang fartstid', detail: 'i barnehagefeltet' },
];

const { items = defaults } = Astro.props;
---

<div class="credentials-strip">
  <p class="credentials-strip__heading">Vår faglige forankring</p>
  <ul class="credentials-strip__list">
    {
      items.map((item) => (
        <li>
          <span class="credentials-strip__label">{item.label}</span>
          {item.detail && <span class="credentials-strip__detail">{item.detail}</span>}
        </li>
      ))
    }
  </ul>
</div>

<style>
  .credentials-strip {
    text-align: center;
  }

  .credentials-strip__heading {
    font-size: 0.78rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--ochre-dark);
    margin-bottom: var(--space-3);
  }

  .credentials-strip__list {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-2) var(--space-4);
    align-items: center;
  }

  .credentials-strip__list li {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    line-height: 1.3;
  }

  .credentials-strip__label {
    font-family: var(--font-serif);
    font-size: 1.15rem;
    color: var(--ink);
    font-weight: 500;
  }

  .credentials-strip__detail {
    font-size: 0.82rem;
    color: var(--ink-soft);
    letter-spacing: 0.04em;
    text-transform: lowercase;
    margin-top: 2px;
  }
</style>
