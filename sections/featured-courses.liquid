{% comment %}
  Featured courses placeholder (Phase 2 scaffolding).
  Optional homepage slot. Empty/opt-in by default: renders nothing until a
  collection is selected in the Theme Editor. No commerce behavior.
{% endcomment %}
{%- assign featured = section.settings.collection -%}
{%- if featured != blank and featured.products_count > 0 -%}
  <section
    {% if section.settings.anchor != blank %}id="{{ section.settings.anchor }}"{% endif %}
    class="section section--{{ section.settings.background }} section--pad-{{ section.settings.padding }}"
  >
    <div class="section__inner">
      <div class="section-heading fade-in">
        {%- if section.settings.eyebrow != blank -%}
          <span class="eyebrow eyebrow--ochre">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2>{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.intro != blank -%}
          <p class="section-lead">{{ section.settings.intro }}</p>
        {%- endif -%}
      </div>

      <div class="featured-courses fade-in">
        {%- for product in featured.products limit: section.settings.limit -%}
          {%- render 'course-card', product: product -%}
        {%- endfor -%}
      </div>
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "Fremhevede kurs",
  "settings": [
    { "type": "paragraph", "content": "Plassholder for kommende kursvisning (fase 2). Velg en samling for å vise kort. Ingen kjøpsfunksjonalitet er aktivert ennå." },
    { "type": "text", "id": "anchor", "label": "Anker-ID" },
    { "type": "collection", "id": "collection", "label": "Samling" },
    { "type": "range", "id": "limit", "label": "Maks antall", "min": 2, "max": 12, "step": 1, "default": 3 },
    { "type": "text", "id": "eyebrow", "label": "Overtekst", "default": "Kommende kurs" },
    { "type": "text", "id": "heading", "label": "Overskrift", "default": "Bli med på kurs" },
    { "type": "textarea", "id": "intro", "label": "Ingress" },
    { "type": "header", "content": "Utseende" },
    {
      "type": "select",
      "id": "background",
      "label": "Bakgrunn",
      "options": [
        { "value": "cream", "label": "Krem" },
        { "value": "cream-warm", "label": "Varm krem" },
        { "value": "paper", "label": "Papir (hvit)" },
        { "value": "moss", "label": "Mose (mørk)" }
      ],
      "default": "paper"
    },
    {
      "type": "select",
      "id": "padding",
      "label": "Luft over/under",
      "options": [
        { "value": "small", "label": "Liten" },
        { "value": "default", "label": "Standard" },
        { "value": "large", "label": "Stor" }
      ],
      "default": "default"
    }
  ],
  "presets": [{ "name": "Fremhevede kurs" }]
}
{% endschema %}
