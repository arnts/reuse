<section
  {% if section.settings.anchor != blank %}id="{{ section.settings.anchor }}"{% endif %}
  class="section section--{{ section.settings.background }} section--pad-{{ section.settings.padding }}"
>
  <div class="section__inner">
    <div class="section-head fade-in">
      {%- if section.settings.eyebrow != blank -%}
        <span class="eyebrow eyebrow--ochre">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2>{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.intro != blank -%}
        <p>{{ section.settings.intro }}</p>
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 0 -%}
      <div class="audience-grid fade-in">
        {%- for block in section.blocks -%}
          <a href="{{ block.settings.link | default: '#' }}" class="audience-card" {{ block.shopify_attributes }}>
            <div class="audience-card__image">
              {% render 'editorial-image',
                image: block.settings.image,
                fallback: block.settings.fallback,
                alt: block.settings.image_alt,
                widths: '300,450,600,800',
                sizes: '(max-width: 600px) 100vw, (max-width: 1000px) 50vw, 25vw',
                width: 800,
                height: 600
              %}
            </div>
            <div class="audience-card__body">
              {%- if block.settings.title != blank -%}
                <h3 class="audience-card__title">{{ block.settings.title }}</h3>
              {%- endif -%}
              {%- if block.settings.tagline != blank -%}
                <p class="audience-card__tagline">{{ block.settings.tagline }}</p>
              {%- endif -%}
              {%- if block.settings.description != blank -%}
                <p class="audience-card__desc">{{ block.settings.description }}</p>
              {%- endif -%}
              {%- if block.settings.cta_label != blank -%}
                <span class="audience-card__cta">
                  {{ block.settings.cta_label }}
                  <span class="arrow" aria-hidden="true">→</span>
                </span>
              {%- endif -%}
            </div>
          </a>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Målgrupper",
  "settings": [
    { "type": "text", "id": "anchor", "label": "Anker-ID", "default": "malgrupper" },
    { "type": "text", "id": "eyebrow", "label": "Overtekst", "default": "For hvem" },
    { "type": "text", "id": "heading", "label": "Overskrift", "default": "Hvem skaper vi for?" },
    { "type": "textarea", "id": "intro", "label": "Ingress", "default": "Vi tilrettelegger ulike opplevelser for fire grupper. Velg den som beskriver deg best — så finner du tilbudene som passer." },
    { "type": "header", "content": "Utseende" },
    {
      "type": "select",
      "id": "background",
      "label": "Bakgrunn",
      "options": [
        { "value": "cream", "label": "Krem" },
        { "value": "cream-warm", "label": "Varm krem" },
        { "value": "paper", "label": "Papir (hvit)" },
        { "value": "moss", "label": "Mose (mørk)" }
      ],
      "default": "cream"
    },
    {
      "type": "select",
      "id": "padding",
      "label": "Luft over/under",
      "options": [
        { "value": "small", "label": "Liten" },
        { "value": "default", "label": "Standard" },
        { "value": "large", "label": "Stor" }
      ],
      "default": "default"
    }
  ],
  "blocks": [
    {
      "type": "audience",
      "name": "Målgruppe",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Bilde" },
        { "type": "text", "id": "fallback", "label": "Reservebilde (asset-filnavn)", "info": "Brukes hvis ingen bilde er valgt.", "default": "audience-pedagoger.svg" },
        { "type": "text", "id": "image_alt", "label": "Alternativ tekst" },
        { "type": "text", "id": "title", "label": "Tittel" },
        { "type": "text", "id": "tagline", "label": "Undertittel" },
        { "type": "textarea", "id": "description", "label": "Beskrivelse" },
        { "type": "text", "id": "cta_label", "label": "Lenketekst", "default": "Se tilbud" },
        { "type": "url", "id": "link", "label": "Lenke" }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Målgrupper",
      "blocks": [
        {
          "type": "audience",
          "settings": {
            "fallback": "audience-pedagoger.svg",
            "image_alt": "Voksen og barn utforsker materialer ved et arbeidsbord.",
            "title": "Pedagoger og institusjoner",
            "tagline": "Faglig påfyll forankret i Reggio Emilia.",
            "description": "Kurs, veiledning og foredrag for barnehager, skoler og fagmiljø som ønsker å utvikle praksisen med estetiske prosesser og gjenbruksmaterialer.",
            "cta_label": "Tilbud for pedagoger",
            "link": "#tilbud"
          }
        },
        {
          "type": "audience",
          "settings": {
            "fallback": "audience-familier.svg",
            "image_alt": "Barn samler og bygger med naturmaterialer.",
            "title": "Barn og familier",
            "tagline": "Skapende opplevelser uten skjerm.",
            "description": "Bursdager, workshops og åpen utforskning for barn og unge — meningsfulle stunder hvor hender, tanker og kropp jobber sammen.",
            "cta_label": "Tilbud for familier",
            "link": "#tilbud"
          }
        },
        {
          "type": "audience",
          "settings": {
            "fallback": "audience-bedrifter.svg",
            "image_alt": "Voksne i samspill rundt skapende oppgave.",
            "title": "Bedrifter og organisasjoner",
            "tagline": "Teambuilding med substans og bærekraft.",
            "description": "Skreddersydde workshops som kobler kreativitet, samarbeid og gjenbruk — alternativ til standard teambuilding.",
            "cta_label": "Tilbud for bedrifter",
            "link": "#tilbud"
          }
        },
        {
          "type": "audience",
          "settings": {
            "fallback": "audience-fellesskap.svg",
            "image_alt": "Hender som arbeider sammen rundt et bord.",
            "title": "Fellesskap og møteplass",
            "tagline": "Et åpent rom for tilhørighet.",
            "description": "Drop-in og åpne arrangementer for alle som ønsker et frirom fra det digitale, knytte nye bekjentskap eller bare skape sammen.",
            "cta_label": "Tilbud for fellesskap",
            "link": "#tilbud"
          }
        }
      ]
    }
  ]
}
{% endschema %}
