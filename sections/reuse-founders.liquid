<section
  {% if section.settings.anchor != blank %}id="{{ section.settings.anchor }}"{% endif %}
  class="section section--{{ section.settings.background }} section--pad-{{ section.settings.padding }}"
>
  <div class="section__inner">
    <div class="section-head fade-in">
      {%- if section.settings.eyebrow != blank -%}
        <span class="eyebrow eyebrow--ochre">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2>{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.intro != blank -%}
        <p>{{ section.settings.intro }}</p>
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 0 -%}
      <div class="team-grid fade-in">
        {%- for block in section.blocks -%}
          <article class="team-card" {{ block.shopify_attributes }}>
            <div class="team-card__portrait">
              {% render 'editorial-image',
                image: block.settings.image,
                fallback: block.settings.fallback,
                alt: block.settings.image_alt,
                widths: '220,320,440,600',
                sizes: '(max-width: 600px) 100vw, 220px',
                width: 600,
                height: 600
              %}
            </div>
            <div class="team-card__body">
              {%- if block.settings.role != blank -%}
                <p class="team-card__role">{{ block.settings.role }}</p>
              {%- endif -%}
              {%- if block.settings.name != blank -%}
                <h3 class="team-card__name">{{ block.settings.name }}</h3>
              {%- endif -%}
              {%- assign credentials = block.settings.credentials | newline_to_br | split: '<br />' -%}
              {%- if credentials.size > 0 -%}
                <ul class="team-card__credentials">
                  {%- for line in credentials -%}
                    {%- assign trimmed = line | strip -%}
                    {%- if trimmed != blank -%}
                      <li>{{ trimmed }}</li>
                    {%- endif -%}
                  {%- endfor -%}
                </ul>
              {%- endif -%}
              {%- if block.settings.bio != blank -%}
                <p class="team-card__bio">{{ block.settings.bio }}</p>
              {%- endif -%}
            </div>
          </article>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if section.settings.footer_cta_label != blank -%}
      <div class="section-foot fade-in">
        <a href="{{ section.settings.footer_cta_link | default: '#' }}" class="btn btn--ghost">
          {{ section.settings.footer_cta_label }}
          <span class="arrow" aria-hidden="true">→</span>
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Menneskene bak",
  "settings": [
    { "type": "text", "id": "anchor", "label": "Anker-ID", "default": "team" },
    { "type": "text", "id": "eyebrow", "label": "Overtekst", "default": "Menneskene bak" },
    { "type": "text", "id": "heading", "label": "Overskrift", "default": "To Atelierista. Mange års erfaring." },
    { "type": "textarea", "id": "intro", "label": "Ingress", "default": "Begge utdannet ved Reggio Emilia-instituttet i Stockholm, og med lang fartstid i barnehagefeltet." },
    { "type": "header", "content": "Bunn-knapp" },
    { "type": "text", "id": "footer_cta_label", "label": "Knappetekst", "default": "Møt oss" },
    { "type": "url", "id": "footer_cta_link", "label": "Knappelenke" },
    { "type": "header", "content": "Utseende" },
    {
      "type": "select",
      "id": "background",
      "label": "Bakgrunn",
      "options": [
        { "value": "cream", "label": "Krem" },
        { "value": "cream-warm", "label": "Varm krem" },
        { "value": "paper", "label": "Papir (hvit)" },
        { "value": "moss", "label": "Mose (mørk)" }
      ],
      "default": "cream-warm"
    },
    {
      "type": "select",
      "id": "padding",
      "label": "Luft over/under",
      "options": [
        { "value": "small", "label": "Liten" },
        { "value": "default", "label": "Standard" },
        { "value": "large", "label": "Stor" }
      ],
      "default": "default"
    }
  ],
  "blocks": [
    {
      "type": "founder",
      "name": "Person",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Portrett" },
        { "type": "text", "id": "fallback", "label": "Reservebilde (asset-filnavn)", "default": "team-caroline.jpg" },
        { "type": "text", "id": "image_alt", "label": "Alternativ tekst" },
        { "type": "text", "id": "name", "label": "Navn" },
        { "type": "text", "id": "role", "label": "Rolle" },
        { "type": "textarea", "id": "credentials", "label": "Kvalifikasjoner", "info": "Én per linje." },
        { "type": "textarea", "id": "bio", "label": "Biografi" }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Menneskene bak",
      "blocks": [
        {
          "type": "founder",
          "settings": {
            "fallback": "team-caroline.jpg",
            "image_alt": "Portrett av Caroline",
            "name": "Caroline",
            "role": "Atelierista",
            "credentials": "Atelierista — Reggio Emilia-instituttet, Stockholm\nMaster i barnehagekunnskap, fordypning estetiske fag — Oslomet\nLang erfaring med de yngste barna",
            "bio": "Caroline har et brennende engasjement for estetiske prosesser og er særlig opptatt av hvordan de minste møter materialer på sine egne premisser."
          }
        },
        {
          "type": "founder",
          "settings": {
            "fallback": "team-ann-helen.jpg",
            "image_alt": "Portrett av Ann-Helen",
            "name": "Ann-Helen",
            "role": "Atelierista og Pedagogista",
            "credentials": "Atelierista og Pedagogista — Reggio Emilia-instituttet, Stockholm\nUtdannet barnehagelærer\nLang erfaring med de eldste barna",
            "bio": "Ann-Helen kombinerer pedagogikkfaglig dybde med kreativ praksis — særlig i arbeid med barn på vei mot skolealder, ungdom og voksne."
          }
        }
      ]
    }
  ]
}
{% endschema %}
