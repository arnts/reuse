<section
  {% if section.settings.anchor != blank %}id="{{ section.settings.anchor }}"{% endif %}
  class="section section--{{ section.settings.background }} section--pad-{{ section.settings.padding }}"
>
  <div class="section__inner">
    <div class="section-head fade-in">
      {%- if section.settings.eyebrow != blank -%}
        <span class="eyebrow eyebrow--ochre">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2>{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.intro != blank -%}
        <p>{{ section.settings.intro }}</p>
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 0 -%}
      <div class="services-grid fade-in">
        {%- for block in section.blocks -%}
          <article class="service-card" {{ block.shopify_attributes }}>
            <div class="service-card__image">
              {% render 'editorial-image',
                image: block.settings.image,
                fallback: block.settings.fallback,
                alt: block.settings.image_alt,
                widths: '300,450,600,800',
                sizes: '(max-width: 720px) 100vw, 33vw',
                width: 800,
                height: 500
              %}
            </div>
            <div class="service-card__body">
              {%- if block.settings.audience_tag != blank -%}
                <span class="service-card__audience">{{ block.settings.audience_tag }}</span>
              {%- endif -%}
              {%- if block.settings.title != blank -%}
                <h3 class="service-card__title">{{ block.settings.title }}</h3>
              {%- endif -%}
              {%- if block.settings.summary != blank -%}
                <p class="service-card__summary">{{ block.settings.summary }}</p>
              {%- endif -%}

              {%- if block.settings.for_whom != blank or block.settings.format != blank -%}
                <dl class="service-card__meta">
                  {%- if block.settings.for_whom != blank -%}
                    <div>
                      <dt>For hvem</dt>
                      <dd>{{ block.settings.for_whom }}</dd>
                    </div>
                  {%- endif -%}
                  {%- if block.settings.format != blank -%}
                    <div>
                      <dt>Format</dt>
                      <dd>{{ block.settings.format }}</dd>
                    </div>
                  {%- endif -%}
                </dl>
              {%- endif -%}

              {%- if block.settings.takeaway != blank -%}
                <p class="service-card__takeaway">
                  <span class="service-card__takeaway-label">Du sitter igjen med:</span>
                  {{ block.settings.takeaway }}
                </p>
              {%- endif -%}

              {%- if block.settings.cta_label != blank -%}
                <a href="{{ block.settings.cta_link | default: '#kontakt' }}" class="btn btn--primary btn--small service-card__cta">
                  {{ block.settings.cta_label }}
                  <span class="arrow" aria-hidden="true">→</span>
                </a>
              {%- endif -%}
            </div>
          </article>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if section.settings.footer_cta_label != blank -%}
      <div class="section-foot fade-in">
        <a href="{{ section.settings.footer_cta_link | default: '#' }}" class="btn btn--secondary">
          {{ section.settings.footer_cta_label }}
          <span class="arrow" aria-hidden="true">→</span>
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Tilbud",
  "settings": [
    { "type": "text", "id": "anchor", "label": "Anker-ID", "default": "tilbud" },
    { "type": "text", "id": "eyebrow", "label": "Overtekst", "default": "Tilbud" },
    { "type": "text", "id": "heading", "label": "Overskrift", "default": "Våre mest etterspurte tilbud" },
    { "type": "textarea", "id": "intro", "label": "Ingress", "default": "Tre rammer som folk kommer tilbake til. Alt skreddersys etter din gruppe." },
    { "type": "header", "content": "Bunn-knapp" },
    { "type": "text", "id": "footer_cta_label", "label": "Knappetekst", "default": "Se alle tilbud" },
    { "type": "url", "id": "footer_cta_link", "label": "Knappelenke" },
    { "type": "header", "content": "Utseende" },
    {
      "type": "select",
      "id": "background",
      "label": "Bakgrunn",
      "options": [
        { "value": "cream", "label": "Krem" },
        { "value": "cream-warm", "label": "Varm krem" },
        { "value": "paper", "label": "Papir (hvit)" },
        { "value": "moss", "label": "Mose (mørk)" }
      ],
      "default": "paper"
    },
    {
      "type": "select",
      "id": "padding",
      "label": "Luft over/under",
      "options": [
        { "value": "small", "label": "Liten" },
        { "value": "default", "label": "Standard" },
        { "value": "large", "label": "Stor" }
      ],
      "default": "default"
    }
  ],
  "blocks": [
    {
      "type": "offering",
      "name": "Tilbud",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Bilde" },
        { "type": "text", "id": "fallback", "label": "Reservebilde (asset-filnavn)", "default": "service-kurs.svg" },
        { "type": "text", "id": "image_alt", "label": "Alternativ tekst" },
        { "type": "text", "id": "audience_tag", "label": "Målgruppe-etikett" },
        { "type": "text", "id": "title", "label": "Tittel" },
        { "type": "textarea", "id": "summary", "label": "Sammendrag" },
        { "type": "text", "id": "for_whom", "label": "For hvem" },
        { "type": "text", "id": "format", "label": "Format" },
        { "type": "textarea", "id": "takeaway", "label": "Du sitter igjen med" },
        { "type": "text", "id": "cta_label", "label": "Knappetekst" },
        { "type": "url", "id": "cta_link", "label": "Knappelenke" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Tilbud",
      "blocks": [
        {
          "type": "offering",
          "settings": {
            "fallback": "service-kurs.svg",
            "image_alt": "Pedagoger i workshop rundt et bord med materialer.",
            "audience_tag": "For pedagoger",
            "title": "Kurs i skapende gjenbruk",
            "summary": "Praksisnære kurs på kveldstid og i helger for barnehager og skoler.",
            "for_whom": "Pedagoger, lærere, fagledere",
            "format": "Kveld eller helg · 3–6 timer · gruppe",
            "takeaway": "Konkrete metoder og praktisk erfaring som kan tas rett tilbake til arbeidshverdagen.",
            "cta_label": "Forespør kurs i skapende gjenbruk",
            "cta_link": "#kontakt"
          }
        },
        {
          "type": "offering",
          "settings": {
            "fallback": "service-bursdag.svg",
            "image_alt": "Bursdagsbord med kreative materialer og barnehender.",
            "audience_tag": "For familier",
            "title": "Kreative bursdager",
            "summary": "Bursdagsfeiring som er like minneverdig som meningsfull.",
            "for_whom": "Barn fra ca. 4 år · 6–15 deltakere",
            "format": "2 timer · etter avtale",
            "takeaway": "En bursdag barna husker, og en pause fra skjermer for foreldre og venner.",
            "cta_label": "Forespør kreative bursdager",
            "cta_link": "#kontakt"
          }
        },
        {
          "type": "offering",
          "settings": {
            "fallback": "service-teambuilding.svg",
            "image_alt": "Kollegaer arbeider sammen rundt en kreativ oppgave.",
            "audience_tag": "For bedrifter",
            "title": "Teambuilding for bedrifter",
            "summary": "Samarbeid og kreativitet — uten klisjeer.",
            "for_whom": "Team og avdelinger · 6–25 deltakere",
            "format": "2–4 timer · skreddersys",
            "takeaway": "Ny innsikt i hverandre, samtaler som tar med seg verdier som mot, lytting og samspill.",
            "cta_label": "Forespør teambuilding for bedrifter",
            "cta_link": "#kontakt"
          }
        }
      ]
    }
  ]
}
{% endschema %}
