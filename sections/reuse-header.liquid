{%- liquid
  assign logo = section.settings.logo
-%}
<header class="site-header" id="site-header" data-site-header>
  <div class="header-inner">
    <a href="{{ routes.root_url }}" class="brand" aria-label="{{ 'general.back_to_home' | t }}">
      {%- if logo != blank -%}
        {{
          logo
          | image_url: width: 480
          | image_tag:
            loading: 'eager',
            widths: '160,240,320,480',
            sizes: '160px',
            alt: section.settings.logo_alt | default: shop.name,
            class: 'brand__logo'
        }}
      {%- else -%}
        <img
          src="{{ 'brand-logo.png' | asset_url }}"
          alt="{{ section.settings.logo_alt | default: shop.name | escape }}"
          class="brand__logo"
          width="4000"
          height="1432"
          loading="eager"
        >
      {%- endif -%}
    </a>

    <button
      class="menu-toggle"
      type="button"
      aria-label="{{ 'header.menu_open' | t }}"
      aria-expanded="false"
      aria-controls="primary-nav"
    >
      <span class="menu-toggle__bar"></span>
      <span class="menu-toggle__bar"></span>
      <span class="menu-toggle__bar"></span>
    </button>

    <nav id="primary-nav" class="primary-nav" aria-label="{{ 'header.primary_navigation' | t }}">
      <ul class="nav-list">
        {%- for block in section.blocks -%}
          {%- if block.type == 'nav_link' and block.settings.enabled -%}
            {%- liquid
              assign link_url = block.settings.link
              assign is_active = false
              if link_url == request.path
                assign is_active = true
              endif
            -%}
            <li {{ block.shopify_attributes }}>
              <a
                href="{{ link_url }}"
                class="nav-link{% if is_active %} is-active{% endif %}"
                {% if is_active %}aria-current="page"{% endif %}
              >
                {{ block.settings.label }}
              </a>
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>

      {%- if section.settings.cta_label != blank -%}
        <a href="{{ section.settings.cta_link }}" class="btn btn--clay btn--small header-cta">
          {{ section.settings.cta_label }}
          <span class="arrow" aria-hidden="true">→</span>
        </a>
      {%- endif -%}

      {%- if section.settings.show_cart -%}
        <a href="{{ routes.cart_url }}" class="header-cart" aria-label="{{ 'header.cart_count' | t: count: cart.item_count }}">
          <span class="header-cart__label">{{ 'header.cart' | t }}</span>
          <span class="header-cart__count" aria-hidden="true">{{ cart.item_count }}</span>
        </a>
      {%- endif -%}
    </nav>
  </div>
</header>

{% schema %}
{
  "name": "Topptekst",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo",
      "info": "Erstatter standardlogoen. Anbefalt bredde minst 480 px."
    },
    {
      "type": "text",
      "id": "logo_alt",
      "label": "Alternativ tekst for logo",
      "default": "REuse Atelier — Kreative hender & Kreative hoder"
    },
    {
      "type": "header",
      "content": "Handlingsknapp"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Knappetekst",
      "default": "Send forespørsel"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Knappelenke"
    },
    {
      "type": "header",
      "content": "Handlekurv"
    },
    {
      "type": "checkbox",
      "id": "show_cart",
      "label": "Vis handlekurv-lenke",
      "default": false,
      "info": "Slå på når kurs legges ut for salg (fase 2)."
    }
  ],
  "blocks": [
    {
      "type": "nav_link",
      "name": "Navigasjonslenke",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Etikett",
          "default": "Lenke"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Lenke"
        },
        {
          "type": "checkbox",
          "id": "enabled",
          "label": "Vis lenken",
          "default": true,
          "info": "Slå av hvis lenken peker til en seksjon på forsiden som er skjult eller fjernet, så unngår du en lenke uten mål."
        }
      ]
    }
  ],
  "max_blocks": 8
}
{% endschema %}
