<section
  {% if section.settings.anchor != blank %}id="{{ section.settings.anchor }}"{% endif %}
  class="section section--{{ section.settings.background }} section--pad-{{ section.settings.padding }}"
>
  <div class="section__inner">
    <div class="fade-in">
      <div class="credentials-strip">
        {%- if section.settings.heading != blank -%}
          <p class="credentials-strip__heading">{{ section.settings.heading }}</p>
        {%- endif -%}
        {%- if section.blocks.size > 0 -%}
          <ul class="credentials-strip__list">
            {%- for block in section.blocks -%}
              <li {{ block.shopify_attributes }}>
                <span class="credentials-strip__label">{{ block.settings.label }}</span>
                {%- if block.settings.detail != blank -%}
                  <span class="credentials-strip__detail">{{ block.settings.detail }}</span>
                {%- endif -%}
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Faglig forankring",
  "settings": [
    { "type": "text", "id": "anchor", "label": "Anker-ID", "default": "troverdighet" },
    { "type": "text", "id": "heading", "label": "Overskrift", "default": "Vår faglige forankring" },
    { "type": "header", "content": "Utseende" },
    {
      "type": "select",
      "id": "background",
      "label": "Bakgrunn",
      "options": [
        { "value": "cream", "label": "Krem" },
        { "value": "cream-warm", "label": "Varm krem" },
        { "value": "paper", "label": "Papir (hvit)" },
        { "value": "moss", "label": "Mose (mørk)" }
      ],
      "default": "cream"
    },
    {
      "type": "select",
      "id": "padding",
      "label": "Luft over/under",
      "options": [
        { "value": "small", "label": "Liten" },
        { "value": "default", "label": "Standard" },
        { "value": "large", "label": "Stor" }
      ],
      "default": "small"
    }
  ],
  "blocks": [
    {
      "type": "credential",
      "name": "Kvalifikasjon",
      "settings": [
        { "type": "text", "id": "label", "label": "Etikett", "default": "Reggio Emilia-instituttet" },
        { "type": "text", "id": "detail", "label": "Detalj", "default": "Stockholm" }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Faglig forankring",
      "blocks": [
        { "type": "credential", "settings": { "label": "Reggio Emilia-instituttet", "detail": "Stockholm" } },
        { "type": "credential", "settings": { "label": "Atelierista", "detail": "utdanning" } },
        { "type": "credential", "settings": { "label": "Pedagogista", "detail": "utdanning" } },
        { "type": "credential", "settings": { "label": "Master estetiske fag", "detail": "Oslomet" } },
        { "type": "credential", "settings": { "label": "Lang fartstid", "detail": "i barnehagefeltet" } }
      ]
    }
  ]
}
{% endschema %}
