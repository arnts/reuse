<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-grid">
      <div class="footer-col footer-col--brand">
        <p class="footer-brand">{{ section.settings.brand | default: shop.name }}</p>
        {%- if section.settings.tagline != blank -%}
          <p class="footer-tagline">{{ section.settings.tagline }}</p>
        {%- endif -%}
      </div>

      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'link_column' -%}
            <div class="footer-col" {{ block.shopify_attributes }}>
              {%- if block.settings.heading != blank -%}
                <p class="footer-heading">{{ block.settings.heading }}</p>
              {%- endif -%}
              <ul>
                {%- for i in (1..5) -%}
                  {%- assign label_key = 'link_' | append: i | append: '_label' -%}
                  {%- assign url_key = 'link_' | append: i | append: '_url' -%}
                  {%- assign label = block.settings[label_key] -%}
                  {%- assign url = block.settings[url_key] -%}
                  {%- if label != blank -%}
                    <li>
                      {%- if url != blank -%}
                        <a href="{{ url }}"{% if block.settings.external %} target="_blank" rel="noopener noreferrer"{% endif %}>{{ label }}</a>
                      {%- else -%}
                        {{ label }}
                      {%- endif -%}
                    </li>
                  {%- endif -%}
                {%- endfor -%}
              </ul>
            </div>
          {%- when 'text_column' -%}
            <div class="footer-col" {{ block.shopify_attributes }}>
              {%- if block.settings.heading != blank -%}
                <p class="footer-heading">{{ block.settings.heading }}</p>
              {%- endif -%}
              {%- if block.settings.text != blank -%}
                <p class="footer-text">{{ block.settings.text }}</p>
              {%- endif -%}
              {%- if block.settings.subtext != blank -%}
                <p class="footer-text footer-text--small">{{ block.settings.subtext }}</p>
              {%- endif -%}
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>

    <div class="footer-bar">
      <p>© {{ 'now' | date: '%Y' }} {{ section.settings.brand | default: shop.name }}</p>
      {%- if section.settings.credit != blank -%}
        <p class="footer-bar__credit">{{ section.settings.credit }}</p>
      {%- endif -%}
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Bunntekst",
  "settings": [
    {
      "type": "text",
      "id": "brand",
      "label": "Merkenavn",
      "default": "REuse Atelier"
    },
    {
      "type": "textarea",
      "id": "tagline",
      "label": "Ingress",
      "default": "Et atelier for skapende prosesser med gjenbruksmaterialer — i Oslo."
    },
    {
      "type": "text",
      "id": "credit",
      "label": "Bunnlinje-tekst",
      "default": "Laget med omtanke"
    }
  ],
  "blocks": [
    {
      "type": "link_column",
      "name": "Lenkekolonne",
      "settings": [
        { "type": "text", "id": "heading", "label": "Overskrift" },
        { "type": "checkbox", "id": "external", "label": "Åpne lenker i ny fane", "default": false },
        { "type": "text", "id": "link_1_label", "label": "Lenke 1 – etikett" },
        { "type": "url", "id": "link_1_url", "label": "Lenke 1 – URL" },
        { "type": "text", "id": "link_2_label", "label": "Lenke 2 – etikett" },
        { "type": "url", "id": "link_2_url", "label": "Lenke 2 – URL" },
        { "type": "text", "id": "link_3_label", "label": "Lenke 3 – etikett" },
        { "type": "url", "id": "link_3_url", "label": "Lenke 3 – URL" },
        { "type": "text", "id": "link_4_label", "label": "Lenke 4 – etikett" },
        { "type": "url", "id": "link_4_url", "label": "Lenke 4 – URL" },
        { "type": "text", "id": "link_5_label", "label": "Lenke 5 – etikett" },
        { "type": "url", "id": "link_5_url", "label": "Lenke 5 – URL" }
      ]
    },
    {
      "type": "text_column",
      "name": "Tekstkolonne",
      "settings": [
        { "type": "text", "id": "heading", "label": "Overskrift" },
        { "type": "textarea", "id": "text", "label": "Tekst" },
        { "type": "text", "id": "subtext", "label": "Undertekst" }
      ]
    }
  ]
}
{% endschema %}
