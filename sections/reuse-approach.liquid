<section
  {% if section.settings.anchor != blank %}id="{{ section.settings.anchor }}"{% endif %}
  class="section section--{{ section.settings.background }} section--pad-{{ section.settings.padding }}"
>
  <div class="section__inner">
    <div class="philosophy">
      <div class="philosophy__head fade-in">
        {%- if section.settings.eyebrow != blank -%}
          <span class="eyebrow eyebrow--cream">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2>{{ section.settings.heading }}</h2>
        {%- endif -%}
      </div>

      <div class="philosophy__columns">
        <div class="fade-in">
          {%- for block in section.blocks -%}
            {%- if block.type == 'paragraph' -%}
              <p {{ block.shopify_attributes }}>{{ block.settings.text }}</p>
            {%- endif -%}
          {%- endfor -%}
        </div>

        {%- if section.settings.quote != blank -%}
          <div class="fade-in">
            <figure class="quote">
              <span class="quote__mark" aria-hidden="true">«</span>
              <blockquote>{{ section.settings.quote }}</blockquote>
              {%- if section.settings.quote_attribution != blank -%}
                <figcaption>— {{ section.settings.quote_attribution }}</figcaption>
              {%- endif -%}
            </figure>
          </div>
        {%- endif -%}
      </div>

      {%- if section.settings.cta_label != blank -%}
        <div class="philosophy__cta fade-in">
          <a href="{{ section.settings.cta_link | default: '#' }}" class="btn btn--ghost">
            {{ section.settings.cta_label }}
            <span class="arrow" aria-hidden="true">→</span>
          </a>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Tilnærming",
  "settings": [
    { "type": "text", "id": "anchor", "label": "Anker-ID", "default": "filosofi" },
    { "type": "text", "id": "eyebrow", "label": "Overtekst", "default": "Vår tilnærming" },
    { "type": "text", "id": "heading", "label": "Overskrift", "default": "Hvorfor skapende gjenbruk virker" },
    { "type": "header", "content": "Sitat" },
    { "type": "textarea", "id": "quote", "label": "Sitat", "default": "Det er i prosessene hender, tanker og kropp flettes sammen." },
    { "type": "text", "id": "quote_attribution", "label": "Kilde", "default": "Vår praksis" },
    { "type": "header", "content": "Knapp" },
    { "type": "text", "id": "cta_label", "label": "Knappetekst", "default": "Les mer om vår tilnærming" },
    { "type": "url", "id": "cta_link", "label": "Knappelenke" },
    { "type": "header", "content": "Utseende" },
    {
      "type": "select",
      "id": "background",
      "label": "Bakgrunn",
      "options": [
        { "value": "cream", "label": "Krem" },
        { "value": "cream-warm", "label": "Varm krem" },
        { "value": "paper", "label": "Papir (hvit)" },
        { "value": "moss", "label": "Mose (mørk)" }
      ],
      "default": "moss"
    },
    {
      "type": "select",
      "id": "padding",
      "label": "Luft over/under",
      "options": [
        { "value": "small", "label": "Liten" },
        { "value": "default", "label": "Standard" },
        { "value": "large", "label": "Stor" }
      ],
      "default": "default"
    }
  ],
  "blocks": [
    {
      "type": "paragraph",
      "name": "Avsnitt",
      "settings": [
        { "type": "richtext", "id": "text", "label": "Tekst", "default": "<p>Materialer uten klare regler tvinger oss til å tenke selv.</p>" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Tilnærming",
      "blocks": [
        { "type": "paragraph", "settings": { "text": "<p>Reggio Emilia-tradisjonen lærer oss at materialer er språk. Når vi tilbyr gjenbruksmaterialer fremfor ferdige produkter, skifter vi fokus fra <em>resultat</em> til <em>prosess</em>. Det er der den virkelige læringen og opplevelsen ligger.</p>" } },
        { "type": "paragraph", "settings": { "text": "<p>Materialer uten klare regler tvinger oss til å tenke selv. De er en demokratisk inngang som ikke favoriserer de som «kan», men inviterer alle.</p>" } }
      ]
    }
  ]
}
{% endschema %}
