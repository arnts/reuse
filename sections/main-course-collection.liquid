{%- comment -%}
  Course collection page. Renders the collection's products in its configured
  sort order (curated manually in Shopify Admin). No ecommerce filters, sorting
  controls, vendor or product-type metadata. Clear empty state.
{%- endcomment -%}
<section class="section section--cream section--pad-default">
  <div class="section__inner">
    <div class="section-head">
      <h1>{{ collection.title | default: section.settings.heading }}</h1>
      {%- if collection.description != blank -%}
        <div class="rte">{{ collection.description }}</div>
      {%- elsif section.settings.intro != blank -%}
        <p>{{ section.settings.intro }}</p>
      {%- endif -%}
    </div>

    {%- if collection.products_count > 0 -%}
      <div class="featured-courses__grid">
        {%- for product in collection.products -%}
          {%- render 'course-card', product: product -%}
        {%- endfor -%}
      </div>
    {%- else -%}
      <p class="featured-courses__empty">{{ section.settings.empty_text }}</p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Kurssamling",
  "settings": [
    { "type": "paragraph", "content": "Viser kursene i samlingen i samlingens egen sorteringsrekkefølge. Ingen filtre eller sorteringsvalg. Kurér rekkefølgen manuelt i Shopify Admin." },
    { "type": "text", "id": "heading", "label": "Overskrift (brukes hvis samlingen mangler tittel)", "default": "Kurs" },
    { "type": "textarea", "id": "intro", "label": "Ingress (brukes hvis samlingen mangler beskrivelse)" },
    { "type": "text", "id": "empty_text", "label": "Tekst når tom", "default": "Ingen kommende kurs akkurat nå. Følg med — nye datoer legges ut fortløpende." }
  ]
}
{% endschema %}
